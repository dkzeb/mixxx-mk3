<!DOCTYPE skin>
<skin>
  <manifest>
    <title>MK3</title>
    <author>mixx-mk3</author>
    <version>2.0</version>
    <description>Native resolution skin for NI Maschine MK3 dual 480x272 screens (960x272)</description>
    <language>en</language>
    <license>MIT</license>
    <attributes>
      <attribute config_key="[App],num_decks">2</attribute>
      <attribute persist="true" config_key="[Skin],active_deck_a">1</attribute>
      <attribute persist="true" config_key="[Skin],active_deck_b">0</attribute>
      <attribute config_key="[Skin],show_library">0</attribute>
      <attribute config_key="[Skin],hide_deck_a">0</attribute>
      <attribute config_key="[Skin],hide_deck_b">0</attribute>
      <attribute config_key="[Skin],show_mixer">0</attribute>
      <attribute config_key="[Skin],shift_held">0</attribute>
      <attribute config_key="[Skin],show_pads_loops">0</attribute>
      <attribute config_key="[Skin],show_pads_fx">0</attribute>
      <attribute config_key="[Skin],show_pads_cues">0</attribute>
    </attributes>
  </manifest>

  <ObjectName>Mixxx</ObjectName>
  <MinimumSize>960,272</MinimumSize>
  <MaximumSize>960,272</MaximumSize>
  <SizePolicy>f,f</SizePolicy>
  <Layout>horizontal</Layout>
  <Style src="skin:style.qss"/>

  <Children>

    <!-- ═══════ LEFT SCREEN: DECK A (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>DeckA</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],hide_deck_a</ConfigKey>
        <BindProperty>visible</BindProperty>
        <Transform><Not/></Transform>
      </Connection>
      <Children>

        <!-- Active deck indicator -->
        <WidgetGroup>
          <ObjectName>DeckAHighlight</ObjectName>
          <Size>480,3</Size>
          <SizePolicy>me,f</SizePolicy>
          <Connection>
            <ConfigKey>[Skin],active_deck_a</ConfigKey>
            <BindProperty>visible</BindProperty>
          </Connection>
        </WidgetGroup>

        <!-- D-button labels (top, aligned with D1-D4) -->
        <WidgetGroup>
          <ObjectName>DButtonLabels</ObjectName>
          <Size>480,12</Size>
          <SizePolicy>me,f</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>
            <Label><ObjectName>DLabel</ObjectName><Size>120,12</Size><Text>SYNC</Text></Label>
            <Label><ObjectName>DLabel</ObjectName><Size>120,12</Size><Text>TEMPO-</Text></Label>
            <Label><ObjectName>DLabel</ObjectName><Size>120,12</Size><Text>TEMPO+</Text></Label>
            <WidgetGroup>
              <Size>120,12</Size><SizePolicy>f,f</SizePolicy>
              <Children>
                <Label><ObjectName>DLabel</ObjectName><Size>120,12</Size><Text>CUE</Text>
                  <Connection><ConfigKey>[Channel1],pfl</ConfigKey><BindProperty>visible</BindProperty><Transform><Not/></Transform></Connection>
                </Label>
                <Label><ObjectName>DLabelActive</ObjectName><Size>120,12</Size><Text>CUE</Text>
                  <Connection><ConfigKey>[Channel1],pfl</ConfigKey><BindProperty>visible</BindProperty></Connection>
                </Label>
              </Children>
            </WidgetGroup>
          </Children>
        </WidgetGroup>

        <!-- Track info (single row: title — artist) -->
        <WidgetGroup>
          <ObjectName>TrackInfoA</ObjectName>
          <SizePolicy>me,min</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>
            <TrackProperty>
              <ObjectName>TrackTitle</ObjectName>
              <Property>title</Property>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Elide>right</Elide>
            </TrackProperty>
            <TrackProperty>
              <ObjectName>TrackArtist</ObjectName>
              <Property>artist</Property>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Elide>right</Elide>
            </TrackProperty>
          </Children>
        </WidgetGroup>

        <!-- Waveform overview -->
        <Overview>
          <ObjectName>WaveformOverviewA</ObjectName>
          <Channel>1</Channel>
          <Size>480,24</Size>
          <SizePolicy>me,f</SizePolicy>
          <BgColor>#1a1a2e</BgColor>
          <SignalColor>#16a085</SignalColor>
          <SignalLowColor>#e74c3c</SignalLowColor>
          <SignalMidColor>#f39c12</SignalMidColor>
          <SignalHighColor>#3498db</SignalHighColor>
          <PlayPosColor>#ffffff</PlayPosColor>
          <EndOfTrackColor>#ff0000</EndOfTrackColor>
          <PlayedOverlayColor>#40000000</PlayedOverlayColor>
          <Connection>
            <ConfigKey>[Channel1],playposition</ConfigKey>
          </Connection>
        </Overview>

        <!-- Scrolling waveform -->
        <Visual>
          <ObjectName>WaveformA</ObjectName>
          <Channel>1</Channel>
          <SizePolicy>me,me</SizePolicy>
          <BgColor>#0d0d1a</BgColor>
          <SignalColor>#16a085</SignalColor>
          <SignalLowColor>#e74c3c</SignalLowColor>
          <SignalMidColor>#f39c12</SignalMidColor>
          <SignalHighColor>#3498db</SignalHighColor>
          <PlayPosColor>#ffffff</PlayPosColor>
          <EndOfTrackColor>#ff0000</EndOfTrackColor>
          <BeatColor>#40ffffff</BeatColor>
          <AxesColor>#40ffffff</AxesColor>
          <MarkRange>
            <StartControl>loop_start_position</StartControl>
            <EndControl>loop_end_position</EndControl>
            <EnabledControl>loop_enabled</EnabledControl>
            <Color>#00FF00</Color>
            <Opacity>0.5</Opacity>
            <DisabledColor>#16a085</DisabledColor>
            <DisabledOpacity>0.2</DisabledOpacity>
          </MarkRange>
          <Mark>
            <Control>loop_start_position</Control>
            <Text>IN</Text>
            <Align>top</Align>
            <Color>#00FF00</Color>
            <TextColor>#FFFFFF</TextColor>
          </Mark>
          <Mark>
            <Control>loop_end_position</Control>
            <Text>OUT</Text>
            <Align>top</Align>
            <Color>#00FF00</Color>
            <TextColor>#FFFFFF</TextColor>
          </Mark>
          <Mark>
            <Control>cue_point</Control>
            <Text>CUE</Text>
            <Align>bottom</Align>
            <Color>#FF001C</Color>
            <TextColor>#FFFFFF</TextColor>
          </Mark>
          <Mark><Control>hotcue_1_position</Control><Text>1</Text><Align>bottom</Align><Color>#F39C12</Color><TextColor>#000000</TextColor></Mark>
          <Mark><Control>hotcue_2_position</Control><Text>2</Text><Align>bottom</Align><Color>#F39C12</Color><TextColor>#000000</TextColor></Mark>
          <Mark><Control>hotcue_3_position</Control><Text>3</Text><Align>bottom</Align><Color>#F39C12</Color><TextColor>#000000</TextColor></Mark>
          <Mark><Control>hotcue_4_position</Control><Text>4</Text><Align>bottom</Align><Color>#F39C12</Color><TextColor>#000000</TextColor></Mark>
          <Mark><Control>hotcue_5_position</Control><Text>5</Text><Align>bottom</Align><Color>#3498DB</Color><TextColor>#FFFFFF</TextColor></Mark>
          <Mark><Control>hotcue_6_position</Control><Text>6</Text><Align>bottom</Align><Color>#3498DB</Color><TextColor>#FFFFFF</TextColor></Mark>
          <Mark><Control>hotcue_7_position</Control><Text>7</Text><Align>bottom</Align><Color>#3498DB</Color><TextColor>#FFFFFF</TextColor></Mark>
          <Mark><Control>hotcue_8_position</Control><Text>8</Text><Align>bottom</Align><Color>#3498DB</Color><TextColor>#FFFFFF</TextColor></Mark>
        </Visual>

        <!-- BPM and position -->
        <WidgetGroup>
          <ObjectName>DeckStatusA</ObjectName>
          <SizePolicy>me,min</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>
            <NumberBpm>
              <ObjectName>BPMDisplay</ObjectName>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Connection>
                <ConfigKey>[Channel1],visual_bpm</ConfigKey>
              </Connection>
            </NumberBpm>
            <NumberPos>
              <ObjectName>PositionDisplay</ObjectName>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Connection>
                <ConfigKey>[Channel1],playposition</ConfigKey>
              </Connection>
            </NumberPos>
          </Children>
        </WidgetGroup>

        <!-- Knob labels (bottom, aligned with K1-K4) -->
        <!-- Shift held: show shift labels -->
        <WidgetGroup>
          <ObjectName>KnobLabels</ObjectName><Size>480,12</Size><SizePolicy>me,f</SizePolicy>
          <Layout>horizontal</Layout>
          <Connection><ConfigKey>[Skin],shift_held</ConfigKey><BindProperty>visible</BindProperty></Connection>
          <Children>
            <Label><ObjectName>KnobLabelShift</ObjectName><Size>120,12</Size><Text>TEMPO</Text></Label>
            <Label><ObjectName>KnobLabelShift</ObjectName><Size>120,12</Size><Text>ZOOM</Text></Label>
            <Label><ObjectName>KnobLabelShift</ObjectName><Size>120,12</Size><Text>VOL</Text></Label>
            <Label><ObjectName>KnobLabelShift</ObjectName><Size>120,12</Size><Text>FILTER</Text></Label>
          </Children>
        </WidgetGroup>
        <!-- No shift, no mixer: normal labels -->
        <WidgetGroup>
          <ObjectName>KnobLabels</ObjectName><Size>480,12</Size><SizePolicy>me,f</SizePolicy>
          <Layout>horizontal</Layout>
          <Connection><ConfigKey>[Skin],shift_held</ConfigKey><BindProperty>visible</BindProperty><Transform><Not/></Transform></Connection>
          <Children>
            <!-- Nested: show normal or mixer based on show_mixer -->
            <WidgetGroup>
              <SizePolicy>me,f</SizePolicy><Layout>horizontal</Layout>
              <Connection><ConfigKey>[Skin],show_mixer</ConfigKey><BindProperty>visible</BindProperty><Transform><Not/></Transform></Connection>
              <Children>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>TEMPO</Text></Label>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>JOG</Text></Label>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>VOL</Text></Label>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>FILTER</Text></Label>
              </Children>
            </WidgetGroup>
            <WidgetGroup>
              <SizePolicy>me,f</SizePolicy><Layout>horizontal</Layout>
              <Connection><ConfigKey>[Skin],show_mixer</ConfigKey><BindProperty>visible</BindProperty></Connection>
              <Children>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>HI</Text></Label>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>MID</Text></Label>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>LO</Text></Label>
                <Label><ObjectName>KnobLabel</ObjectName><Size>120,12</Size><Text>VOL</Text></Label>
              </Children>
            </WidgetGroup>
          </Children>
        </WidgetGroup>

      </Children>
    </WidgetGroup>

    <!-- ═══════ LIBRARY PANEL (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>LibraryPanel</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],show_library</ConfigKey>
        <BindProperty>visible</BindProperty>
      </Connection>
      <Children>
        <Library>
          <ObjectName>LibraryView</ObjectName>
          <SizePolicy>me,me</SizePolicy>
        </Library>
      </Children>
    </WidgetGroup>

    <!-- ═══════ MIXER PANEL (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>MixerPanel</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],show_mixer</ConfigKey>
        <BindProperty>visible</BindProperty>
      </Connection>
      <Children>
        <Label><ObjectName>MixerTitle</ObjectName><Size>480,16</Size><Text>MIXER</Text></Label>
        <WidgetGroup>
          <SizePolicy>me,me</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>

            <!-- Deck A strip -->
            <WidgetGroup>
              <ObjectName>MixerStripA</ObjectName>
              <Size>240,0</Size>
              <SizePolicy>f,me</SizePolicy>
              <Layout>vertical</Layout>
              <Children>
                <Label><ObjectName>MixerChLabel</ObjectName><Size>240,14</Size><Text>DECK A</Text></Label>
                <!-- VU Meter -->
                <VuMeter>
                  <ObjectName>VuMeterA</ObjectName>
                  <Size>200,8</Size>
                  <SizePolicy>me,f</SizePolicy>
                  <PathVu>skin:vu_fill.png</PathVu>
                  <PathBack>skin:vu_bg.png</PathBack>
                  <Horizontal>true</Horizontal>
                  <PeakHoldSize>3</PeakHoldSize>
                  <PeakHoldTime>500</PeakHoldTime>
                  <PeakFallTime>50</PeakFallTime>
                  <PeakFallStep>2</PeakFallStep>
                  <Connection><ConfigKey>[Channel1],vu_meter</ConfigKey></Connection>
                </VuMeter>
                <!-- Knob labels: K1=HI K2=MID K3=LO K4=VOL -->
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K1: HI</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel1]_Effect1],parameter3</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K2: MID</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel1]_Effect1],parameter2</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K3: LO</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel1]_Effect1],parameter1</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K4: VOL</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel1],volume</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>GAIN</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel1],pregain</ConfigKey></Connection>
                </SliderComposed>
              </Children>
            </WidgetGroup>

            <!-- Deck B strip -->
            <WidgetGroup>
              <ObjectName>MixerStripB</ObjectName>
              <Size>240,0</Size>
              <SizePolicy>f,me</SizePolicy>
              <Layout>vertical</Layout>
              <Children>
                <Label><ObjectName>MixerChLabel</ObjectName><Size>240,14</Size><Text>DECK B</Text></Label>
                <!-- VU Meter -->
                <VuMeter>
                  <ObjectName>VuMeterB</ObjectName>
                  <Size>200,8</Size>
                  <SizePolicy>me,f</SizePolicy>
                  <PathVu>skin:vu_fill.png</PathVu>
                  <PathBack>skin:vu_bg.png</PathBack>
                  <Horizontal>true</Horizontal>
                  <PeakHoldSize>3</PeakHoldSize>
                  <PeakHoldTime>500</PeakHoldTime>
                  <PeakFallTime>50</PeakFallTime>
                  <PeakFallStep>2</PeakFallStep>
                  <Connection><ConfigKey>[Channel2],vu_meter</ConfigKey></Connection>
                </VuMeter>
                <!-- Knob labels: K5=HI K6=MID K7=LO K8=VOL -->
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K5: HI</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel2]_Effect1],parameter3</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K6: MID</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel2]_Effect1],parameter2</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K7: LO</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel2]_Effect1],parameter1</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>K8: VOL</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel2],volume</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,10</Size><Text>GAIN</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,14</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel2],pregain</ConfigKey></Connection>
                </SliderComposed>
              </Children>
            </WidgetGroup>

          </Children>
        </WidgetGroup>

        <!-- Crossfader (full width) -->
        <Label><ObjectName>MixerKnobLabel</ObjectName><Size>480,10</Size><Text>CROSSFADER</Text></Label>
        <SliderComposed>
          <ObjectName>MixerCrossfader</ObjectName>
          <Size>470,16</Size>
          <SizePolicy>me,f</SizePolicy>
          <Horizontal>true</Horizontal>
          <Handle>skin:crossfader_handle.png</Handle>
          <Slider>skin:crossfader_bg.png</Slider>
          <Connection>
            <ConfigKey>[Master],crossfader</ConfigKey>
          </Connection>
        </SliderComposed>
      </Children>
    </WidgetGroup>

    <!-- ═══════ PAD INFO: LOOPS (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>PadPanel</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],show_pads_loops</ConfigKey>
        <BindProperty>visible</BindProperty>
      </Connection>
      <Children>
        <Label><ObjectName>PadTitle</ObjectName><Size>480,20</Size><Text>LOOPS</Text></Label>

        <!-- 4x4 grid showing pad assignments -->
        <WidgetGroup>
          <ObjectName>PadGrid</ObjectName>
          <SizePolicy>me,me</SizePolicy>
          <Layout>vertical</Layout>
          <Children>
            <!-- Top row: pads 13-16 (short loops) -->
            <WidgetGroup>
              <SizePolicy>me,me</SizePolicy>
              <Layout>horizontal</Layout>
              <Children>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>1/16</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>1/8</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>1/4</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>1/2</Text></Label>
              </Children>
            </WidgetGroup>
            <!-- Row 2: pads 9-12 -->
            <WidgetGroup>
              <SizePolicy>me,me</SizePolicy>
              <Layout>horizontal</Layout>
              <Children>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>1</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>2</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>4</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>8</Text></Label>
              </Children>
            </WidgetGroup>
            <!-- Row 3: pads 5-8 -->
            <WidgetGroup>
              <SizePolicy>me,me</SizePolicy>
              <Layout>horizontal</Layout>
              <Children>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>16</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>32</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>64</Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text>128</Text></Label>
              </Children>
            </WidgetGroup>
            <!-- Bottom row: pads 1-4 (actions) -->
            <WidgetGroup>
              <SizePolicy>me,me</SizePolicy>
              <Layout>horizontal</Layout>
              <Children>
                <Label><ObjectName>PadCellAction</ObjectName><SizePolicy>me,me</SizePolicy><Text>HALVE</Text></Label>
                <Label><ObjectName>PadCellAction</ObjectName><SizePolicy>me,me</SizePolicy><Text>DOUBLE</Text></Label>
                <Label><ObjectName>PadCellAction</ObjectName><SizePolicy>me,me</SizePolicy><Text>RELOOP</Text></Label>
                <Label><ObjectName>PadCellAction</ObjectName><SizePolicy>me,me</SizePolicy><Text>EXIT</Text></Label>
              </Children>
            </WidgetGroup>
          </Children>
        </WidgetGroup>
      </Children>
    </WidgetGroup>

    <!-- ═══════ PAD INFO: EFFECTS (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>PadPanel</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],show_pads_fx</ConfigKey>
        <BindProperty>visible</BindProperty>
      </Connection>
      <Children>
        <Label><ObjectName>PadTitle</ObjectName><Size>480,20</Size><Text>EFFECTS</Text></Label>
        <WidgetGroup>
          <ObjectName>PadGrid</ObjectName>
          <SizePolicy>me,me</SizePolicy>
          <Layout>vertical</Layout>
          <Children>
            <!-- FX pads: only bottom row active (1-4) -->
            <WidgetGroup>
              <SizePolicy>me,me</SizePolicy>
              <Layout>horizontal</Layout>
              <Children>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
              </Children>
            </WidgetGroup>
            <WidgetGroup>
              <SizePolicy>me,me</SizePolicy>
              <Layout>horizontal</Layout>
              <Children>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
              </Children>
            </WidgetGroup>
            <WidgetGroup>
              <SizePolicy>me,me</SizePolicy>
              <Layout>horizontal</Layout>
              <Children>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
                <Label><ObjectName>PadCell</ObjectName><SizePolicy>me,me</SizePolicy><Text></Text></Label>
