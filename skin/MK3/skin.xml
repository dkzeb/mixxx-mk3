<!DOCTYPE skin>
<skin>
  <manifest>
    <title>MK3</title>
    <author>mixx-mk3</author>
    <version>2.0</version>
    <description>Native resolution skin for NI Maschine MK3 dual 480x272 screens (960x272)</description>
    <language>en</language>
    <license>MIT</license>
    <attributes>
      <attribute config_key="[App],num_decks">2</attribute>
      <attribute persist="true" config_key="[Skin],active_deck_a">1</attribute>
      <attribute persist="true" config_key="[Skin],active_deck_b">0</attribute>
      <attribute config_key="[Skin],show_library">0</attribute>
      <attribute config_key="[Skin],hide_deck_a">0</attribute>
      <attribute config_key="[Skin],hide_deck_b">0</attribute>
      <attribute config_key="[Skin],show_mixer">0</attribute>
    </attributes>
  </manifest>

  <ObjectName>Mixxx</ObjectName>
  <MinimumSize>960,272</MinimumSize>
  <MaximumSize>960,272</MaximumSize>
  <SizePolicy>f,f</SizePolicy>
  <Layout>horizontal</Layout>
  <Style src="skin:style.qss"/>

  <Children>

    <!-- ═══════ LEFT SCREEN: DECK A (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>DeckA</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],hide_deck_a</ConfigKey>
        <BindProperty>visible</BindProperty>
        <Transform><Not/></Transform>
      </Connection>
      <Children>

        <!-- Active deck indicator -->
        <WidgetGroup>
          <ObjectName>DeckAHighlight</ObjectName>
          <Size>480,3</Size>
          <SizePolicy>me,f</SizePolicy>
          <Connection>
            <ConfigKey>[Skin],active_deck_a</ConfigKey>
            <BindProperty>visible</BindProperty>
          </Connection>
        </WidgetGroup>

        <!-- Track info (single row: title — artist) -->
        <WidgetGroup>
          <ObjectName>TrackInfoA</ObjectName>
          <SizePolicy>me,min</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>
            <TrackProperty>
              <ObjectName>TrackTitle</ObjectName>
              <Property>title</Property>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Elide>right</Elide>
            </TrackProperty>
            <TrackProperty>
              <ObjectName>TrackArtist</ObjectName>
              <Property>artist</Property>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Elide>right</Elide>
            </TrackProperty>
          </Children>
        </WidgetGroup>

        <!-- Waveform overview -->
        <Overview>
          <ObjectName>WaveformOverviewA</ObjectName>
          <Channel>1</Channel>
          <Size>480,24</Size>
          <SizePolicy>me,f</SizePolicy>
          <BgColor>#1a1a2e</BgColor>
          <SignalColor>#16a085</SignalColor>
          <SignalLowColor>#e74c3c</SignalLowColor>
          <SignalMidColor>#f39c12</SignalMidColor>
          <SignalHighColor>#3498db</SignalHighColor>
          <PlayPosColor>#ffffff</PlayPosColor>
          <EndOfTrackColor>#ff0000</EndOfTrackColor>
          <PlayedOverlayColor>#40000000</PlayedOverlayColor>
          <Connection>
            <ConfigKey>[Channel1],playposition</ConfigKey>
          </Connection>
        </Overview>

        <!-- Scrolling waveform -->
        <Visual>
          <ObjectName>WaveformA</ObjectName>
          <Channel>1</Channel>
          <SizePolicy>me,me</SizePolicy>
          <BgColor>#0d0d1a</BgColor>
          <SignalColor>#16a085</SignalColor>
          <SignalLowColor>#e74c3c</SignalLowColor>
          <SignalMidColor>#f39c12</SignalMidColor>
          <SignalHighColor>#3498db</SignalHighColor>
          <PlayPosColor>#ffffff</PlayPosColor>
          <EndOfTrackColor>#ff0000</EndOfTrackColor>
          <BeatColor>#40ffffff</BeatColor>
          <AxesColor>#40ffffff</AxesColor>
        </Visual>

        <!-- BPM and position -->
        <WidgetGroup>
          <ObjectName>DeckStatusA</ObjectName>
          <SizePolicy>me,min</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>
            <NumberBpm>
              <ObjectName>BPMDisplay</ObjectName>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Connection>
                <ConfigKey>[Channel1],visual_bpm</ConfigKey>
              </Connection>
            </NumberBpm>
            <NumberPos>
              <ObjectName>PositionDisplay</ObjectName>
              <Channel>1</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Connection>
                <ConfigKey>[Channel1],playposition</ConfigKey>
              </Connection>
            </NumberPos>
          </Children>
        </WidgetGroup>

      </Children>
    </WidgetGroup>

    <!-- ═══════ LIBRARY PANEL (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>LibraryPanel</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],show_library</ConfigKey>
        <BindProperty>visible</BindProperty>
      </Connection>
      <Children>
        <SearchBox>
          <ObjectName>LibrarySearch</ObjectName>
          <Size>480,22</Size>
          <SizePolicy>me,f</SizePolicy>
        </SearchBox>
        <Library>
          <ObjectName>LibraryView</ObjectName>
          <SizePolicy>me,me</SizePolicy>
        </Library>
      </Children>
    </WidgetGroup>

    <!-- ═══════ MIXER PANEL (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>MixerPanel</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],show_mixer</ConfigKey>
        <BindProperty>visible</BindProperty>
      </Connection>
      <Children>
        <Label><ObjectName>MixerTitle</ObjectName><Size>480,18</Size><Text>MIXER</Text></Label>
        <WidgetGroup>
          <SizePolicy>me,me</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>

            <!-- Deck A strip -->
            <WidgetGroup>
              <ObjectName>MixerStripA</ObjectName>
              <Size>240,0</Size>
              <SizePolicy>f,me</SizePolicy>
              <Layout>vertical</Layout>
              <Children>
                <Label><ObjectName>MixerChLabel</ObjectName><Size>240,16</Size><Text>DECK A</Text></Label>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>GAIN</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel1],pregain</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>HI</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel1]_Effect1],parameter3</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>MID</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel1]_Effect1],parameter2</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>LO</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel1]_Effect1],parameter1</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>VOL</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel1],volume</ConfigKey></Connection>
                </SliderComposed>
              </Children>
            </WidgetGroup>

            <!-- Deck B strip -->
            <WidgetGroup>
              <ObjectName>MixerStripB</ObjectName>
              <Size>240,0</Size>
              <SizePolicy>f,me</SizePolicy>
              <Layout>vertical</Layout>
              <Children>
                <Label><ObjectName>MixerChLabel</ObjectName><Size>240,16</Size><Text>DECK B</Text></Label>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>GAIN</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel2],pregain</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>HI</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel2]_Effect1],parameter3</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>MID</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel2]_Effect1],parameter2</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>LO</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[EqualizerRack1_[Channel2]_Effect1],parameter1</ConfigKey></Connection>
                </SliderComposed>
                <Label><ObjectName>MixerKnobLabel</ObjectName><Size>240,12</Size><Text>VOL</Text></Label>
                <SliderComposed>
                  <ObjectName>MixerSlider</ObjectName><Size>200,16</Size><SizePolicy>me,f</SizePolicy>
                  <Horizontal>true</Horizontal>
                  <Handle>skin:slider_handle.png</Handle><Slider>skin:slider_bg.png</Slider>
                  <Connection><ConfigKey>[Channel2],volume</ConfigKey></Connection>
                </SliderComposed>
              </Children>
            </WidgetGroup>

          </Children>
        </WidgetGroup>
      </Children>
    </WidgetGroup>

    <!-- ═══════ RIGHT SCREEN: DECK B (480x272) ═══════ -->
    <WidgetGroup>
      <ObjectName>DeckB</ObjectName>
      <Size>480,272</Size>
      <SizePolicy>f,f</SizePolicy>
      <Layout>vertical</Layout>
      <Connection>
        <ConfigKey>[Skin],hide_deck_b</ConfigKey>
        <BindProperty>visible</BindProperty>
        <Transform><Not/></Transform>
      </Connection>
      <Children>

        <!-- Active deck indicator -->
        <WidgetGroup>
          <ObjectName>DeckBHighlight</ObjectName>
          <Size>480,3</Size>
          <SizePolicy>me,f</SizePolicy>
          <Connection>
            <ConfigKey>[Skin],active_deck_b</ConfigKey>
            <BindProperty>visible</BindProperty>
          </Connection>
        </WidgetGroup>

        <!-- Track info (single row) -->
        <WidgetGroup>
          <ObjectName>TrackInfoB</ObjectName>
          <SizePolicy>me,min</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>
            <TrackProperty>
              <ObjectName>TrackTitle</ObjectName>
              <Property>title</Property>
              <Channel>2</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Elide>right</Elide>
            </TrackProperty>
            <TrackProperty>
              <ObjectName>TrackArtist</ObjectName>
              <Property>artist</Property>
              <Channel>2</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Elide>right</Elide>
            </TrackProperty>
          </Children>
        </WidgetGroup>

        <!-- Waveform overview -->
        <Overview>
          <ObjectName>WaveformOverviewB</ObjectName>
          <Channel>2</Channel>
          <Size>480,24</Size>
          <SizePolicy>me,f</SizePolicy>
          <BgColor>#1a1a2e</BgColor>
          <SignalColor>#e67e22</SignalColor>
          <SignalLowColor>#e74c3c</SignalLowColor>
          <SignalMidColor>#f39c12</SignalMidColor>
          <SignalHighColor>#3498db</SignalHighColor>
          <PlayPosColor>#ffffff</PlayPosColor>
          <EndOfTrackColor>#ff0000</EndOfTrackColor>
          <PlayedOverlayColor>#40000000</PlayedOverlayColor>
          <Connection>
            <ConfigKey>[Channel2],playposition</ConfigKey>
          </Connection>
        </Overview>

        <!-- Scrolling waveform -->
        <Visual>
          <ObjectName>WaveformB</ObjectName>
          <Channel>2</Channel>
          <SizePolicy>me,me</SizePolicy>
          <BgColor>#0d0d1a</BgColor>
          <SignalColor>#e67e22</SignalColor>
          <SignalLowColor>#e74c3c</SignalLowColor>
          <SignalMidColor>#f39c12</SignalMidColor>
          <SignalHighColor>#3498db</SignalHighColor>
          <PlayPosColor>#ffffff</PlayPosColor>
          <EndOfTrackColor>#ff0000</EndOfTrackColor>
          <BeatColor>#40ffffff</BeatColor>
          <AxesColor>#40ffffff</AxesColor>
        </Visual>

        <!-- BPM and position -->
        <WidgetGroup>
          <ObjectName>DeckStatusB</ObjectName>
          <SizePolicy>me,min</SizePolicy>
          <Layout>horizontal</Layout>
          <Children>
            <NumberBpm>
              <ObjectName>BPMDisplay</ObjectName>
              <Channel>2</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Connection>
                <ConfigKey>[Channel2],visual_bpm</ConfigKey>
              </Connection>
            </NumberBpm>
            <NumberPos>
              <ObjectName>PositionDisplay</ObjectName>
              <Channel>2</Channel>
              <SizePolicy>me,min</SizePolicy>
              <Connection>
                <ConfigKey>[Channel2],playposition</ConfigKey>
              </Connection>
            </NumberPos>
          </Children>
        </WidgetGroup>

      </Children>
    </WidgetGroup>

  </Children>
</skin>
